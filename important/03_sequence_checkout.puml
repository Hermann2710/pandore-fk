@startuml sequence_checkout
skinparam sequenceArrowThickness 2
skinparam roundcorner 10

actor Customer
participant "Next.js\nFrontend" as FE
participant "Django\nBackend" as BE
database "Database" as DB

== Cart → Checkout ==

Customer -> FE : Click "Proceed to Checkout"
FE -> BE : GET /api/addresses/
BE -> DB : SELECT shipping_addresses WHERE user=me
DB --> BE : addresses[]
BE --> FE : addresses[]

FE -> BE : GET /api/payments/methods/
BE -> DB : SELECT payment_methods WHERE is_active=true
DB --> BE : methods[]
BE --> FE : methods[]

FE --> Customer : Show checkout page\n(address step)

== Step 1 — Address ==

Customer -> FE : Select/enter shipping address
Customer -> FE : Click "Continue to Payment"
FE --> Customer : Show payment step

== Step 2 — Payment ==

Customer -> FE : Select payment method
Customer -> FE : Click "Place Order"

FE -> BE : POST /api/orders/checkout/\n{shipping_address, payment_method_id, items[]}
BE -> DB : Validate stock for each product
DB --> BE : stock OK

BE -> DB : BEGIN TRANSACTION\nCreate Order\nCreate OrderItems\nDecrement stock\nCreate Payment (pending)
DB --> BE : order created
BE --> FE : Order data {id, ...}

== Payment Simulation ==

FE --> Customer : Show "Processing Payment…" screen
note right : 2 second delay

FE -> BE : POST /api/payments/{orderId}/confirm/
BE -> DB : UPDATE payment SET status=confirmed,\ntransaction_ref=SIM-XXXX
DB --> BE : payment updated
BE --> FE : {status: confirmed, transaction_ref}

FE --> Customer : Show confirmation screen\n(order id + transaction ref)

FE -> FE : clearCart()

@enduml
