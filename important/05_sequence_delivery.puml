@startuml sequence_delivery
skinparam sequenceArrowThickness 2
skinparam roundcorner 10

actor Admin
actor "Delivery Man" as DM
participant "Frontend" as FE
participant "Backend" as BE
database "Database" as DB

== Admin assigns order ==

Admin -> FE : View pending orders
FE -> BE : GET /api/orders/admin/?status=pending
BE --> FE : orders[]

Admin -> FE : Click "Assign" on order #X\nSelect delivery man
FE -> BE : POST /api/orders/admin/{id}/assign/\n{delivery_man_id, notes}
BE -> DB : Create DeliveryAssignment\nUPDATE order.status = assigned
DB --> BE : OK
BE --> FE : Updated order
FE --> Admin : Order marked as "Assigned"

== Delivery man updates status ==

DM -> FE : View delivery queue
FE -> BE : GET /api/orders/delivery/queue/
BE -> DB : SELECT orders via DeliveryAssignment\nWHERE delivery_man=me
DB --> BE : orders[]
BE --> FE : orders[]

loop For each status transition
  DM -> FE : Click "Update Status"
  FE -> BE : PATCH /api/orders/delivery/{id}/status/
  BE -> BE : ALLOWED_TRANSITIONS:\nassigned → picked_up\npicked_up → in_transit\nin_transit → delivered
  BE -> DB : UPDATE order.status = next_status
  DB --> BE : OK
  BE --> FE : Updated order
  FE --> DM : Status updated
end

@enduml
